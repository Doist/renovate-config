{
    "extends": [
        "config:base",
        "group:linters",
        "group:monorepos",
        "group:recommended",
        "schedule:weekdays",
        ":enableVulnerabilityAlerts"
    ],
    "packageRules": [
        {
            "matchManagers": ["github-actions"],
            "enabled": false
        },
        {
            "matchPackageNames": ["@doist/**"],
            "prPriority": 5
        }
    ],
    "minimumReleaseAge": "5 days"
}
